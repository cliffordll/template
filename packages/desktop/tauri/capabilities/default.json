{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "主窗口默认权限:core + shell(sidecar spawn)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/template-server", "sidecar": true, "args": true }
      ]
    },
    "updater:default"
  ]
}
